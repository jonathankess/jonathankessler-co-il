---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const fmt = (d: Date) =>
  d.toLocaleDateString('he-IL', { year: 'numeric', month: 'long', day: 'numeric' });
---
<BaseLayout title="בלוג" description="כתיבה על תרבות, שפה ומקום.">
  <h1>בלוג</h1>
  <ul class="post-list">
    {posts.map((post) => (
      <li>
        <h2><a href={`/blog/${post.id}`}>{post.data.title}</a></h2>
        <time datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>
        <p>{post.data.description}</p>
      </li>
    ))}
  </ul>
</BaseLayout>
