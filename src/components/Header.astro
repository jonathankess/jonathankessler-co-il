---
const links = [
  { href: '/', label: 'ראשי' },
  { href: '/blog', label: 'בלוג' },
  { href: '/now', label: 'עכשיו' },
  { href: '/about', label: 'אודות' },
];
---
<header class="site-header">
  <div class="wrap">
    <a href="/" class="brand">יונתן קסלר</a>
    <nav class="nav">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>
  </div>
</header>
